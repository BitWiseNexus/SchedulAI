# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=development

# Add your email for quick access
DEFAULT_USER_EMAIL=

# ===== GOOGLE API CREDENTIALS =====
# LOCAL DEV: point to your downloaded credentials.json file
GOOGLE_CREDENTIALS_PATH=./credentials.json

# HOSTED DEPLOYMENT (recommended): provide credentials as env vars instead of a file.
# These take priority over credentials.json if set.
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret

# OAuth callback URL. MUST match an "Authorized redirect URI" in Google Cloud Console.
# Local:      http://localhost:5000/auth/google/callback
# Production:  https://your-backend.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ===== GEMINI AI API =====
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ===== DATABASE =====
DATABASE_PATH=./database/mail_calendar.db

# ===== FRONTEND =====
# Where users are redirected after login. Set to your deployed frontend URL in production.
# Local:      http://localhost:5173
# Production:  https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# ===== DEBUG FLAGS =====
DEBUG_MODE=true
LOG_LEVEL=info
